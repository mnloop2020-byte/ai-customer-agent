// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  SALES_MANAGER
  SALES_AGENT
}

enum ChannelType {
  WEB_CHAT
  WHATSAPP
  EMAIL
  INSTAGRAM
  FACEBOOK
  PHONE
}

enum LeadStatus {
  NEW
  QUALIFYING
  HOT
  WARM
  COLD
  UNQUALIFIED
  WON
  LOST
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum QualificationStatus {
  UNKNOWN
  DISCOVERING
  QUALIFIED
  NEEDS_REVIEW
  DISQUALIFIED
}

enum BuyingStage {
  NEW
  DISCOVERY
  QUALIFICATION
  OFFER
  NEGOTIATION
  FOLLOW_UP
  WON
  LOST
}

enum LeadRoute {
  DIRECT_ANSWER
  QUALIFY
  PRESENT_OFFER
  BOOKING
  FOLLOW_UP
  HUMAN_HANDOFF
  DISQUALIFY
}

enum ConversationStatus {
  OPEN
  WAITING_CUSTOMER
  WAITING_AGENT
  ESCALATED
  CLOSED
}

enum MessageSender {
  CUSTOMER
  AI
  HUMAN
  SYSTEM
}

enum DealStatus {
  OPEN
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum FollowUpStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum FollowUpKind {
  BOOKING
  CHECK_DECISION
  CONTINUE_QUALIFICATION
  RECOVER_OBJECTION
  REENGAGE_LOST
}

enum HandoffStatus {
  PENDING
  ACCEPTED
  RESOLVED
  CANCELLED
}

enum KnowledgeDocumentStatus {
  CURRENT
  ARCHIVED
  DRAFT
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  industry    String?
  description String?
  location    String?
  workingHours String?
  handoffRules Json?
  timezone    String   @default("Asia/Amman")
  aiPersona   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  services      Service[]
  leads         Lead[]
  conversations Conversation[]
  integrations  Integration[]
  followUps     FollowUp[]
  aiRuns        AiRun[]
  auditLogs     AuditLog[]
  sessions      Session[]
  knowledgeDocuments KnowledgeDocument[]
  knowledgeChunks    KnowledgeChunk[]
}

model User {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String   @unique
  passwordHash String
  role      UserRole @default(SALES_AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages Message[]
  handoffs Handoff[]
  sessions Session[]
}

model Session {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  priceLabel   String?
  basePrice   Decimal?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@unique([companyId, name])
}

model Lead {
  id               String     @id @default(cuid())
  companyId        String
  serviceId        String?
  fullName         String?
  phone            String?
  email            String?
  city             String?
  companyName      String?
  channel          ChannelType
  status           LeadStatus @default(NEW)
  score            Int        @default(0)
  intent           String?
  customerType     CustomerType?
  preferredContact String?
  budget           String?
  timeline         String?
  decisionMaker    Boolean?
  needsSummary     String?
  qualificationStatus QualificationStatus @default(UNKNOWN)
  buyingStage      BuyingStage @default(NEW)
  route            LeadRoute?
  qualificationSignals Json?
  missingFields    Json?
  agentMemory      Json?
  lastSummary      String?
  lostReason       String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service       Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  deals         Deal[]
  followUps     FollowUp[]
  handoffs      Handoff[]

  @@index([companyId, status, updatedAt])
  @@index([companyId, score])
  @@index([companyId, channel, createdAt])
}

model Conversation {
  id        String             @id @default(cuid())
  companyId String
  leadId    String
  visitorSessionId String?
  channel   ChannelType
  status    ConversationStatus @default(OPEN)
  startedAt DateTime           @default(now())
  closedAt  DateTime?
  updatedAt DateTime           @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]
  aiRuns   AiRun[]

  @@index([companyId, visitorSessionId])
  @@index([companyId, status, updatedAt])
  @@index([leadId, updatedAt])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  userId         String?
  sender         MessageSender
  body           String
  metadata       Json?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([userId])
}

model Deal {
  id        String     @id @default(cuid())
  leadId    String
  title     String
  value     Decimal?
  currency  String     @default("USD")
  status    DealStatus @default(OPEN)
  closedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model FollowUp {
  id        String         @id @default(cuid())
  companyId String
  leadId    String
  kind      FollowUpKind   @default(CHECK_DECISION)
  sequenceKey String?
  stepNumber Int           @default(1)
  status    FollowUpStatus @default(SCHEDULED)
  message   String
  dueAt     DateTime
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId, kind, status, dueAt])
  @@index([leadId, kind, status])
}

model Handoff {
  id        String        @id @default(cuid())
  leadId    String
  userId    String?
  reason    String
  summary   String
  status    HandoffStatus @default(PENDING)
  createdAt DateTime      @default(now())
  resolvedAt DateTime?

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Integration {
  id        String      @id @default(cuid())
  companyId String
  channel   ChannelType
  name      String
  config    Json
  isActive  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AiRun {
  id             String   @id @default(cuid())
  companyId      String
  conversationId String?
  intent         String?
  extractedData  Json?
  scoreDelta     Int      @default(0)
  nextAction     String
  response       String
  createdAt      DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([conversationId, createdAt])
}

model KnowledgeDocument {
  id        String   @id @default(cuid())
  companyId String
  title     String
  status    KnowledgeDocumentStatus @default(CURRENT)
  sourceType String   @default("TEXT")
  sourceName String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks  KnowledgeChunk[]
}

model KnowledgeChunk {
  id        String   @id @default(cuid())
  companyId String
  documentId String
  content   String
  embedding Json?
  position  Int
  createdAt DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([documentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
